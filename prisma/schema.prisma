
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Post {
  id          Int      @id @default(autoincrement())
  title       String   // German (default language)
  titleEn     String?  // English translation
  titleVi     String?  // Vietnamese (admin reference)
  slug        String   @unique
  content     String   @db.Text // German content
  contentEn   String?  @db.Text // English content
  image       String?
  category    String
  author      String
  status      String   @default("published") // published, hidden, draft
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lead {
  id          Int      @id @default(autoincrement())
  type        String   // contact, voucher, consultation
  name        String
  email       String
  phone       String?
  details     String?  @db.Text // JSON string for extra fields
  status      String   @default("new") // new, read, contacted
  createdAt   DateTime @default(now())
}

model PageContent {
  id          Int      @id @default(autoincrement())
  pageKey     String   // e.g. 'home', 'about'
  sectionKey  String   // e.g. 'hero_title', 'about_text'
  content     String   @db.Text // JSON string: { text: "...", image: "..." }
  updatedAt   DateTime @updatedAt
  
  @@unique([pageKey, sectionKey])
}
